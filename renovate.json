{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "packageRules": [
    {
      "description": "Group GitHub Actions updates",
      "matchManagers": [
        "github-actions"
      ],
      "groupName": "GitHub Actions"
    },
    {
      "description": "Group Dockerfile base image updates",
      "matchManagers": [
        "dockerfile"
      ],
      "groupName": "Docker"
    }
  ],
  "schedule": [
    "on monday before 6am"
  ],
  "automerge": false,
  "minimumReleaseAge": "3 days",
  "rangeStrategy": "bump",
  "labels": [
    "dependencies",
    "renovate"
  ]
}